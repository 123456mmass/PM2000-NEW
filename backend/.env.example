# ================================================================
# PM2000 Backend Configuration
# ================================================================
# เลือก MODE ที่ต้องการ:
#   MODE 1 (Direct): ใส่ API Keys ด้านล่าง (สำหรับคนที่มี Key เอง)
#   MODE 2 (Proxy):  ใส่แค่ PROXY_URL + PROXY_APP_KEY (สำหรับเพื่อน)
# ================================================================

# --- MODE 1: Direct API Keys (ไม่ต้องใส่ถ้าใช้ Proxy) ---
MISTRAL_API_KEY=
MISTRAL_AGENT_ID=
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen3.5-plus
DASHSCOPE_FALLBACK_MODEL=qwen-max
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# --- MODE 2: Proxy Mode (ไม่ต้องใส่ถ้ามี Key เอง) ---
PROXY_URL=
PROXY_APP_KEY=